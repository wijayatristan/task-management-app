Table users {
  id integer [primary key, increment]
  name varchar(255) [not null]
  email varchar(255) [not null, unique]
  hashed_password varchar(255) [not null]
  created_at timestamp [not null, default: `now()`]

  Note: 'Application users. Also used as the pool of selectable task assignees.'
}

Table tasks {
  id integer [primary key, increment]
  title varchar(255) [not null]
  description text
  deadline date
  status task_status [not null, default: 'todo']
  assignee_id integer [ref: > users.id, note: 'nullable — a task may be unassigned']
  created_at timestamp [not null, default: `now()`]
  updated_at timestamp [not null, default: `now()`]

  Note: 'One task belongs to at most one assignee (users.id).'
}

Enum task_status {
  todo
  in_progress
  done
}
